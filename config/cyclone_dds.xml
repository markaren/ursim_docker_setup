<CycloneDDS xmlns="https://cdds.io/config">
  <Domain id="any">

    <General>
      <AllowMulticast>false</AllowMulticast>
    </General>

    <Discovery>
      <ParticipantIndex>auto</ParticipantIndex>
      <Peers>
        <!-- Windows host IP: shared by ur_driver (host network) and pixi ROS2 -->
        <Peer address="192.168.1.53"/>
        <!-- Loopback: needed for local participant discovery when multicast is off -->
        <Peer address="127.0.0.1"/>
      </Peers>
    </Discovery>

  </Domain>
</CycloneDDS>
